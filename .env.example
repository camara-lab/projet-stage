# ============================================================
# Bus Booking System - Variables d'environnement (exemple)
# Copier en .env à la racine : cp .env.example .env
# ============================================================

# --- UID/GID hôte (évite les soucis de permissions sur Linux) ---
UID=1000
GID=1000

# --- Symfony ---
APP_ENV=dev
APP_SECRET=ChangeThisSecretToSomethingRandom

# --- Ports exposés côté hôte ---
NGINX_PORT=8080
MYSQL_PORT=3307
PMA_PORT=8081

# --- MySQL ---
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=bus_booking
MYSQL_USER=app
MYSQL_PASSWORD=app
