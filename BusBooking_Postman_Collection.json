              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/payments/booking/{{booking_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "payments", "booking", "{{booking_id}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"method\": \"WAFA_CASH\"\n}"
            }
          },
          "response": []
