              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/payments/booking/12", "host": ["{{base_url}}"], "path": ["api", "payments", "booking", "12"] },
