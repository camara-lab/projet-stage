###############################################################################
# BusGo — Variables d'environnement PRODUCTION
# Copier ce fichier en .env.prod et remplir toutes les valeurs marquées CHANGE_ME
# NE JAMAIS committer .env.prod dans git (il est dans .gitignore)
###############################################################################

###> symfony/framework-bundle ###
APP_ENV=prod
APP_DEBUG=false

# Générer avec : php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=CHANGE_ME_32_chars_random_hex_string
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Format : mysql://USER:PASSWORD@HOST:PORT/DATABASE?serverVersion=8.0&charset=utf8mb4
DATABASE_URL="mysql://busgo_user:CHANGE_ME_strong_password@database:3306/busgo_prod?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
# Générer avec : openssl rand -base64 32
JWT_PASSPHRASE=CHANGE_ME_strong_jwt_passphrase
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
# Regex du/des domaine(s) autorisé(s) — remplacer busgo.ma par votre domaine réel
CORS_ALLOW_ORIGIN='^https://busgo\.ma$'
###< nelmio/cors-bundle ###

###> sécurité cookies ###
# true en production (HTTPS), false uniquement en développement local (HTTP)
COOKIE_SECURE=true
###< sécurité cookies ###

###> base de données Docker ###
MYSQL_DATABASE=busgo_prod
MYSQL_USER=busgo_user
# Générer avec : openssl rand -base64 24
MYSQL_PASSWORD=CHANGE_ME_strong_password
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password_different
###< base de données Docker ###
