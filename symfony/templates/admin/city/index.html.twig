{% extends 'base.html.twig' %}
{% block title %}Villes{% endblock %}
{% block page_title %}Gestion des villes{% endblock %}

{% block body %}

<div class="section-card">
    <div class="section-header">
        <h6 class="section-title"><i class="ti ti-map-pin" style="color:var(--accent-blue)"></i> Villes</h6>
        <a href="{{ path('admin_city_new') }}" style="display:inline-flex;align-items:center;gap:5px;padding:6px 14px;background:var(--accent-blue);color:#fff;border-radius:var(--radius-sm);font-size:12px;font-weight:600;text-decoration:none">
            <i class="ti ti-plus"></i> Nouvelle ville
        </a>
    </div>
    <form method="get" action="{{ path('admin_city_index') }}" class="filter-bar">
        <div class="filter-group">
            <label for="q">Rechercher</label>
            <input id="q" name="q" type="text" value="{{ search }}" placeholder="Nom de la ville…" class="filter-input">
        </div>
        <button type="submit" class="filter-btn"><i class="ti ti-search"></i> Filtrer</button>
        {% if search != '' %}
            <a href="{{ path('admin_city_index') }}" class="filter-reset"><i class="ti ti-x"></i> Réinitialiser</a>
        {% endif %}
    </form>
    <div class="filter-results">{{ cities|length }} villes {{ search != '' ? 'pour « ' ~ search ~ ' »' }}</div>
    <div style="overflow-x:auto">
        <table class="activity-table" style="width:100%">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nom</th>
                    <th>Date creation</th>
                    <th style="text-align:right">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for city in cities %}
                <tr>
                    <td style="color:var(--text-muted);font-size:11px">{{ city.id }}</td>
                    <td>
                        <div style="display:flex;align-items:center;gap:7px">
                            <div style="width:28px;height:28px;border-radius:50%;background:#dbeafe;display:flex;align-items:center;justify-content:center;color:var(--accent-blue);font-size:13px;flex-shrink:0">
                                <i class="ti ti-map-pin"></i>
                            </div>
                            <span style="font-size:13px;font-weight:600;color:var(--text-primary)">{{ city.name }}</span>
                        </div>
                    </td>
                    <td style="font-size:12px;color:var(--text-muted)">{{ city.createdAt|date('d/m/Y') }}</td>
                    <td style="text-align:right;white-space:nowrap">
                        <a href="{{ path('admin_city_edit', {id: city.id}) }}"
                           style="display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border:1px solid var(--card-border);border-radius:6px;font-size:11px;color:var(--text-secondary);text-decoration:none;margin-right:4px"
                           title="Modifier">
                            <i class="ti ti-pencil"></i>
                        </a>
                        <form method="post" action="{{ path('admin_city_delete', {id: city.id}) }}" class="d-inline"
                              onsubmit="return confirm('Supprimer {{ city.name }} ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-city-' ~ city.id) }}">
                            <button style="display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border:1px solid #fecaca;border-radius:6px;font-size:11px;color:var(--accent-red);background:transparent;cursor:pointer"
                                    title="Supprimer">
                                <i class="ti ti-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="4" style="text-align:center;padding:32px;color:var(--text-muted);font-size:13px">
                        <i class="ti ti-map-pin-off" style="font-size:24px;display:block;margin-bottom:8px"></i>
                        Aucune ville enregistrée.
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% endblock %}
