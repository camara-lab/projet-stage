{% extends 'base.html.twig' %}
{% block title %}Paramètres{% endblock %}
{% block page_title %}Paramètres{% endblock %}

{% block body %}

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:start">

    {# ── Profil ── #}
    <div class="section-card">
        <div class="section-header">
            <h6 class="section-title"><i class="ti ti-user" style="color:var(--accent-blue)"></i> Informations du profil</h6>
        </div>
        <div style="padding:20px">

            {# Avatar centré #}
            <div style="text-align:center;margin-bottom:20px">
                <div style="width:64px;height:64px;background:var(--accent-blue);border-radius:50%;display:inline-flex;align-items:center;justify-content:center;color:#fff;font-size:24px;font-weight:700">
                    {{ admin.email|slice(0,1)|upper }}
                </div>
                <div style="margin-top:8px;font-size:13px;font-weight:600;color:var(--text-primary)">{{ admin.fullName }}</div>
                <div style="font-size:11px;color:var(--text-muted)">{{ admin.email }}</div>
                <span style="display:inline-block;margin-top:4px;background:#dbeafe;color:#1e40af;font-size:10px;font-weight:700;padding:2px 8px;border-radius:20px">ADMIN</span>
            </div>

            <form method="post" action="{{ path('admin_settings_index') }}">
                <input type="hidden" name="section" value="profile">
                <input type="hidden" name="_token" value="{{ csrf_token('admin-settings') }}">

                <div style="margin-bottom:14px">
                    <label style="display:block;font-size:12px;font-weight:600;color:var(--text-secondary);margin-bottom:5px">Nom complet *</label>
                    <input type="text" name="full_name" value="{{ admin.fullName }}"
                           style="width:100%;padding:9px 12px;border:1px solid var(--card-border);border-radius:var(--radius-sm);font-size:13px;font-family:var(--font);outline:none;transition:border-color .15s"
                           onfocus="this.style.borderColor='var(--accent-blue)'"
                           onblur="this.style.borderColor='var(--card-border)'"
                           required>
                    {% if errors.full_name is defined %}
                        <span style="font-size:11px;color:var(--accent-red)">{{ errors.full_name }}</span>
                    {% endif %}
                </div>

                <div style="margin-bottom:14px">
                    <label style="display:block;font-size:12px;font-weight:600;color:var(--text-secondary);margin-bottom:5px">Email</label>
                    <input type="email" value="{{ admin.email }}" disabled
                           style="width:100%;padding:9px 12px;border:1px solid var(--card-border);border-radius:var(--radius-sm);font-size:13px;background:#f8fafc;color:var(--text-muted);cursor:not-allowed">
                    <span style="font-size:10.5px;color:var(--text-muted)">L'email ne peut pas être modifié ici.</span>
                </div>

                <div style="margin-bottom:18px">
                    <label style="display:block;font-size:12px;font-weight:600;color:var(--text-secondary);margin-bottom:5px">Téléphone</label>
                    <input type="tel" name="phone" value="{{ admin.phone ?? '' }}"
                           placeholder="+212 6XX XXX XXX"
                           style="width:100%;padding:9px 12px;border:1px solid var(--card-border);border-radius:var(--radius-sm);font-size:13px;font-family:var(--font);outline:none;transition:border-color .15s"
                           onfocus="this.style.borderColor='var(--accent-blue)'"
                           onblur="this.style.borderColor='var(--card-border)'">
                </div>

                <button type="submit"
                        style="width:100%;padding:10px;background:var(--accent-blue);color:#fff;border:none;border-radius:var(--radius-sm);font-size:13px;font-weight:600;cursor:pointer;font-family:var(--font);transition:background .15s"
                        onmouseover="this.style.background='#2563eb'"
                        onmouseout="this.style.background='var(--accent-blue)'">
                    <i class="ti ti-device-floppy me-1"></i> Enregistrer le profil
                </button>
            </form>
        </div>
    </div>

    {# Colonne droite : mot de passe + infos système #}
    <div style="display:flex;flex-direction:column;gap:20px">

        {# ── Mot de passe ── #}
        <div class="section-card">
            <div class="section-header">
                <h6 class="section-title"><i class="ti ti-lock" style="color:var(--accent-orange)"></i> Changer le mot de passe</h6>
            </div>
            <div style="padding:20px">
                <form method="post" action="{{ path('admin_settings_index') }}">
                    <input type="hidden" name="section" value="password">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin-settings') }}">

                    <div style="margin-bottom:14px">
                        <label style="display:block;font-size:12px;font-weight:600;color:var(--text-secondary);margin-bottom:5px">Mot de passe actuel *</label>
                        <input type="password" name="current_password"
                               style="width:100%;padding:9px 12px;border:1px solid {{ errors.current_password is defined ? 'var(--accent-red)' : 'var(--card-border)' }};border-radius:var(--radius-sm);font-size:13px;font-family:var(--font);outline:none"
                               required>
                        {% if errors.current_password is defined %}
                            <span style="font-size:11px;color:var(--accent-red)">{{ errors.current_password }}</span>
                        {% endif %}
                    </div>

                    <div style="margin-bottom:14px">
                        <label style="display:block;font-size:12px;font-weight:600;color:var(--text-secondary);margin-bottom:5px">Nouveau mot de passe *</label>
                        <input type="password" name="new_password" id="newPwd"
                               style="width:100%;padding:9px 12px;border:1px solid {{ errors.new_password is defined ? 'var(--accent-red)' : 'var(--card-border)' }};border-radius:var(--radius-sm);font-size:13px;font-family:var(--font);outline:none"
                               required minlength="8">
                        {% if errors.new_password is defined %}
                            <span style="font-size:11px;color:var(--accent-red)">{{ errors.new_password }}</span>
                        {% endif %}
                        <div id="pwdStrength" style="height:4px;background:#e2e8f0;border-radius:2px;margin-top:6px;overflow:hidden">
                            <div id="pwdBar" style="height:100%;width:0;border-radius:2px;transition:width .3s,background .3s"></div>
                        </div>
                        <span id="pwdHint" style="font-size:10.5px;color:var(--text-muted)">Min. 8 caractères</span>
                    </div>

                    <div style="margin-bottom:18px">
                        <label style="display:block;font-size:12px;font-weight:600;color:var(--text-secondary);margin-bottom:5px">Confirmer le nouveau mot de passe *</label>
                        <input type="password" name="confirm_password"
                               style="width:100%;padding:9px 12px;border:1px solid {{ errors.confirm_password is defined ? 'var(--accent-red)' : 'var(--card-border)' }};border-radius:var(--radius-sm);font-size:13px;font-family:var(--font);outline:none"
                               required>
                        {% if errors.confirm_password is defined %}
                            <span style="font-size:11px;color:var(--accent-red)">{{ errors.confirm_password }}</span>
                        {% endif %}
                    </div>

                    <button type="submit"
                            style="width:100%;padding:10px;background:var(--accent-orange);color:#fff;border:none;border-radius:var(--radius-sm);font-size:13px;font-weight:600;cursor:pointer;font-family:var(--font);transition:background .15s"
                            onmouseover="this.style.background='#d97706'"
                            onmouseout="this.style.background='var(--accent-orange)'">
                        <i class="ti ti-lock-check me-1"></i> Changer le mot de passe
                    </button>
                </form>
            </div>
        </div>

        {# ── Infos système ── #}
        <div class="section-card">
            <div class="section-header">
                <h6 class="section-title"><i class="ti ti-info-circle" style="color:var(--text-muted)"></i> Informations système</h6>
            </div>
            <div style="padding:0">
                {% set infos = [
                    {label: 'Application',     value: 'Bus Booking System'},
                    {label: 'Environnement',   value: app.environment|upper},
                    {label: 'Version Symfony', value: constant('Symfony\\Component\\HttpKernel\\Kernel::VERSION')},
                    {label: 'Date serveur',    value: 'now'|date('d/m/Y H:i')},
                    {label: 'Compte créé le',  value: admin.createdAt|date('d/m/Y')},
                ] %}
                {% for info in infos %}
                <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 18px;border-bottom:1px solid #f1f5f9">
                    <span style="font-size:12px;color:var(--text-secondary)">{{ info.label }}</span>
                    <span style="font-size:12px;font-weight:600;color:var(--text-primary)">{{ info.value }}</span>
                </div>
                {% endfor %}
            </div>
        </div>

    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
/* ── Indicateur de force du mot de passe ── */
document.getElementById('newPwd').addEventListener('input', function () {
    const v = this.value;
    const bar = document.getElementById('pwdBar');
    const hint = document.getElementById('pwdHint');
    let score = 0;
    if (v.length >= 8)  score++;
    if (/[A-Z]/.test(v)) score++;
    if (/[0-9]/.test(v)) score++;
    if (/[^A-Za-z0-9]/.test(v)) score++;

    const levels = [
        { w: '0%',   bg: '#e2e8f0', txt: 'Min. 8 caractères' },
        { w: '25%',  bg: '#ef4444', txt: 'Faible' },
        { w: '50%',  bg: '#f59e0b', txt: 'Moyen' },
        { w: '75%',  bg: '#3b82f6', txt: 'Fort' },
        { w: '100%', bg: '#10b981', txt: 'Très fort' },
    ];
    const l = v.length === 0 ? levels[0] : levels[score] ?? levels[4];
    bar.style.width = l.w;
    bar.style.background = l.bg;
    hint.textContent = l.txt;
    hint.style.color = l.bg;
});
</script>
{% endblock %}
