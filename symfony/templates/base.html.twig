<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Bus Booking{% endblock %} — Admin</title>

    {# ── Bootstrap ── #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    {# ── Bootstrap Icons (rétrocompatibilité autres pages) ── #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    {# ── Tabler Icons ── #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
    {# ── Admin redesign CSS ── #}
    <link rel="stylesheet" href="{{ asset('css/admin-redesign.css') }}">

    {% block stylesheets %}{% endblock %}
</head>
<body>

{# ══════════════════════════════════════════════════════════
   SIDEBAR + TOPBAR — uniquement si connecté
══════════════════════════════════════════════════════════ #}
{% if app.user %}

<aside class="admin-sidebar">
    <div class="sidebar-logo">
        <div class="sidebar-logo-icon"><i class="ti ti-bus"></i></div>
        <div>
            <span class="sidebar-logo-title">BusAdmin</span>
            <span class="sidebar-logo-sub">Maroc Transport</span>
        </div>
    </div>

    <nav class="sidebar-nav">
        <span class="sidebar-section">Principal</span>
        <a class="sidebar-item {{ app.request.attributes.get('_route') == 'admin_dashboard' ? 'active' }}"
           href="{{ path('admin_dashboard') }}">
            <i class="ti ti-layout-dashboard"></i> Dashboard
        </a>

        <span class="sidebar-section">Configuration</span>
        <a class="sidebar-item {{ app.request.attributes.get('_route') starts with 'admin_city' ? 'active' }}"
           href="{{ path('admin_city_index') }}">
            <i class="ti ti-map-pin"></i> Villes
        </a>
        <a class="sidebar-item {{ app.request.attributes.get('_route') starts with 'admin_bus' ? 'active' }}"
           href="{{ path('admin_bus_index') }}">
            <i class="ti ti-bus"></i> Bus
        </a>
        <a class="sidebar-item {{ app.request.attributes.get('_route') starts with 'admin_route' ? 'active' }}"
           href="{{ path('admin_route_index') }}">
            <i class="ti ti-route"></i> Lignes
        </a>

        <span class="sidebar-section">Opérations</span>
        <a class="sidebar-item {{ app.request.attributes.get('_route') starts with 'admin_trip' ? 'active' }}"
           href="{{ path('admin_trip_index') }}">
            <i class="ti ti-calendar-week"></i> Trajets
        </a>
        <a class="sidebar-item {{ app.request.attributes.get('_route') starts with 'admin_booking' ? 'active' }}"
           href="{{ path('admin_booking_index') }}">
            <i class="ti ti-ticket"></i> Réservations
        </a>
        <a class="sidebar-item {{ app.request.attributes.get('_route') starts with 'admin_payment' ? 'active' }}"
           href="{{ path('admin_payment_index') }}">
            <i class="ti ti-credit-card"></i> Paiements
        </a>

        <span class="sidebar-section">Système</span>
        <a class="sidebar-item {{ app.request.attributes.get('_route') starts with 'admin_settings' ? 'active' }}"
           href="{{ path('admin_settings_index') }}">
            <i class="ti ti-settings"></i> Paramètres
        </a>
    </nav>

    <div class="sidebar-footer">
        <div class="sidebar-footer-avatar">{{ app.user.email|slice(0,1)|upper }}</div>
        <div class="sidebar-footer-info">
            <span class="sidebar-footer-name">{{ app.user.email }}</span>
            <span class="sidebar-footer-role">Administrateur</span>
        </div>
        <a href="{{ path('admin_logout') }}" class="sidebar-logout" title="Déconnexion">
            <i class="ti ti-logout"></i>
        </a>
    </div>
</aside>

<div class="admin-topbar">
    <span class="admin-topbar-title">{% block page_title %}{% endblock %}</span>
    <div style="display:flex;align-items:center;gap:12px">
        <span class="admin-topbar-date">
            <i class="ti ti-calendar" style="margin-right:4px"></i>{{ "now"|date("d/m/Y") }}&nbsp;&nbsp;<i class="ti ti-clock" style="margin-right:3px"></i><span id="topbar-clock"></span>
        </span>
        <span class="admin-topbar-badge">ADMIN</span>
    </div>
</div>

{% endif %}

{# ══════════════════════════════════════════════════════════
   CONTENU PRINCIPAL — toujours rendu (login ou admin)
══════════════════════════════════════════════════════════ #}
<div class="{{ app.user ? 'admin-content' : 'login-wrapper' }}">

    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type == 'success' ? 'success' : (type == 'error' ? 'danger' : 'warning') }} alert-dismissible fade show">
                {{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
/* ── Horloge temps réel dans la topbar ── */
(function tick() {
    const el = document.getElementById('topbar-clock');
    if (el) {
        const now = new Date();
        el.textContent = now.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    }
    setTimeout(tick, 1000);
})();
</script>
{% block javascripts %}{% endblock %}
</body>
</html>
